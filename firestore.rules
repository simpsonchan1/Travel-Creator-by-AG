rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only authenticated users can access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /projects/{projectId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /preferences/{prefId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /images/{imageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Anyone authenticated can read/write to the public brandLibrary
    match /brandLibrary/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null; // Let them delete their own (or all, simplifed)
    }
  }
}
